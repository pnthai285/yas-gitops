# Copy this file to secrets-raw/dev.env and replace every placeholder locally.
# Do not commit secrets-raw/dev.env.

POSTGRESQL_USERNAME=replace-with-dev-postgresql-username
POSTGRESQL_PASSWORD=replace-with-dev-postgresql-password

ELASTICSEARCH_USERNAME=replace-with-dev-elasticsearch-username
ELASTICSEARCH_PASSWORD=replace-with-dev-elasticsearch-password

KEYCLOAK_BACKOFFICE_BFF_CLIENT_SECRET=replace-with-dev-backoffice-bff-client-secret
KEYCLOAK_STOREFRONT_BFF_CLIENT_SECRET=replace-with-dev-storefront-bff-client-secret
KEYCLOAK_CUSTOMER_MANAGEMENT_CLIENT_SECRET=replace-with-dev-customer-management-client-secret

REDIS_PASSWORD=replace-with-dev-redis-password
OPENAI_API_KEY=replace-with-dev-openai-api-key

KEYCLOAK_ADMIN_USERNAME=replace-with-dev-keycloak-admin-username
KEYCLOAK_ADMIN_PASSWORD=replace-with-dev-keycloak-admin-password

PGADMIN_PASSWORD=replace-with-dev-pgadmin-password

GRAFANA_USERNAME=replace-with-dev-grafana-username
GRAFANA_PASSWORD=replace-with-dev-grafana-password
