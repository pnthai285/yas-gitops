# Copy this file to secrets-raw/ephemeral-shared.env and replace every placeholder locally.
# Do not commit secrets-raw/ephemeral-shared.env.
#
# These values are sealed with cluster-wide scope so Jenkins preview namespaces can reuse them.

POSTGRESQL_USERNAME=replace-with-preview-postgresql-username
POSTGRESQL_PASSWORD=replace-with-preview-postgresql-password

ELASTICSEARCH_USERNAME=replace-with-preview-elasticsearch-username
ELASTICSEARCH_PASSWORD=replace-with-preview-elasticsearch-password

KEYCLOAK_BACKOFFICE_BFF_CLIENT_SECRET=replace-with-preview-backoffice-bff-client-secret
KEYCLOAK_STOREFRONT_BFF_CLIENT_SECRET=replace-with-preview-storefront-bff-client-secret
KEYCLOAK_CUSTOMER_MANAGEMENT_CLIENT_SECRET=replace-with-preview-customer-management-client-secret

REDIS_PASSWORD=replace-with-preview-redis-password
OPENAI_API_KEY=replace-with-preview-openai-api-key

KEYCLOAK_ADMIN_USERNAME=replace-with-preview-keycloak-admin-username
KEYCLOAK_ADMIN_PASSWORD=replace-with-preview-keycloak-admin-password

PGADMIN_PASSWORD=replace-with-preview-pgadmin-password

GRAFANA_USERNAME=replace-with-preview-grafana-username
GRAFANA_PASSWORD=replace-with-preview-grafana-password
